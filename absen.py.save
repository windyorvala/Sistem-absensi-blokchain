import sys
from config import w3, contract
# 5 akun bawaan Anvil (alamat + private key) — selalu sama tiap kali anvil dijalankan
AKUN_ANVIL = [
    {"alamat": "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266",
     "private_key": "0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"},
    {"alamat": "0x70997970C51812dc3A010C7d01b50e0d17dc79C8",
     "private_key": "0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690"},
    {"alamat": "0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC",
     "private_key": "0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a"},
    {"alamat": "0x90F79bf6EB2c4f870365E785982E1f101E93b906",
     "private_key": "0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a"},
    {"alamat": "0x15d34AAf54267DB7D7c367839AAf71A00a2C6A65",
     "private_key": "0x47e179ec197488593b187f80a00eb0da91f1b9d0b13f8733639f19c30a34926b"},
]

if len(sys.argv) < 4:
    print('Pemakaian: python3 absen.py "<Nama Pertemuan>" "<Nama Peserta>" <index_akun>')
    sys.exit(1)

nama_pertemuan = sys.argv[1]
nama_peserta = sys.argv[2]
index_akun = int(sys.argv[3])

akun = AKUN_ANVIL[index_akun]
account = w3.eth.account.from_key(akun["private_key"])

print(f'Mencatat absensi "{nama_peserta}" ({account.address}) untuk "{nama_pertemuan}" ...')

tx = contract.functions.absen(nama_pertemuan, nama_peserta).build_transaction({
    "from": account.address,
    "nonce": w3.eth.get_transaction_count(account.address),
    "gas": 200000,
    "gasPrice": w3.eth.gas_price,
})

signed_tx = w3.eth.account.sign_transaction(tx, private_key=akun["private_key"])
tx_hash = w3.eth.send_raw_transaction(signed_tx.raw_transaction)
receipt = w3.eth.wait_for_transaction_receipt(tx_hash)

print("Transaction hash:", tx_hash.hex())
print("Status:", "SUCCESS" if receipt.status == 1 else "FAILED")
print("Gas used:", receipt.gasUsed)
